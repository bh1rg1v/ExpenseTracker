@model ExpenseTracker.Models.Transaction
@{
    ViewData["Title"] = "Add Transaction";
    Layout = "_Layout";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-light btn-sm rounded-3 me-2">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to List
        </a>
        <h1 class="h3 fw-bold text-white mt-3"><i class="fa-solid fa-plus text-primary me-2"></i>Add Transaction</h1>
        <p class="text-muted small">Record a new financial transaction</p>
    </div>

    <div class="card glass-panel border-light border-opacity-10 rounded-3 p-4 shadow">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger-glass small border-0 py-2 px-3 mb-3 text-danger rounded-3" role="alert"></div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label text-light opacity-75 small"></label>
                <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select bg-transparent border-opacity-20 border-light text-light">
                    <option value="" class="bg-dark text-white">-- Select Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Amount" class="form-label text-light opacity-75 small"></label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 border-opacity-20 border-light text-light opacity-50">$</span>
                    <input asp-for="Amount" class="form-control bg-transparent border-start-0 border-opacity-20 border-light text-light" placeholder="0.00" type="number" step="0.01" min="0.01" />
                </div>
                <span asp-validation-for="Amount" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Date" class="form-label text-light opacity-75 small"></label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 border-opacity-20 border-light text-light opacity-50"><i class="fa-solid fa-calendar-days"></i></span>
                    <input asp-for="Date" class="form-control bg-transparent border-start-0 border-opacity-20 border-light text-light" type="date" />
                </div>
                <span asp-validation-for="Date" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label text-light opacity-75 small"></label>
                <textarea asp-for="Description" class="form-control bg-transparent border-opacity-20 border-light text-light" placeholder="Describe the transaction (optional)..." rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 rounded-3 py-2 btn-glow-primary text-white font-weight-bold">
                <i class="fa-solid fa-floppy-disk me-2"></i>Save Transaction
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
