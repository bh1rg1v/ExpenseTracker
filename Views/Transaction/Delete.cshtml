@model ExpenseTracker.Models.Transaction
@{
    ViewData["Title"] = "Delete Transaction";
    Layout = "_Layout";
    var isIncome = Model.Category?.Type == "Income";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-light btn-sm rounded-3">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to List
        </a>
        <h1 class="h3 fw-bold text-white mt-3"><i class="fa-solid fa-trash-can text-danger me-2"></i>Delete Transaction</h1>
        <p class="text-muted small">Are you sure you want to delete this transaction record?</p>
    </div>

    <div class="card glass-panel border-light border-opacity-10 rounded-3 p-4 shadow mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <div class="category-icon-wrapper rounded-3 d-flex align-items-center justify-content-center me-3" 
                     style="background-color: @(Model.Category?.Color + "20"); width: 50px; height: 50px;">
                    <i class="fa-solid @(Model.Category?.Icon ?? "fa-tags") fa-lg" style="color: @Model.Category?.Color"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-white mb-1">@Model.Category?.Name</h5>
                    <span class="badge @(isIncome ? "bg-success-glass text-success" : "bg-danger-glass text-danger") rounded-pill px-2.5 py-1 small">
                        @Model.Category?.Type
                    </span>
                </div>
            </div>
            <div class="text-end">
                <h3 class="fw-bold mb-0 @(isIncome ? "text-success" : "text-danger")">
                    @(isIncome ? "+" : "-") $@Model.Amount.ToString("N2")
                </h3>
            </div>
        </div>

        <hr class="border-light border-opacity-10" />

        <div class="text-light opacity-75 small">
            <p class="mb-2"><strong>Transaction Date:</strong> @Model.Date.ToString("yyyy-MM-dd")</p>
            <p class="mb-0"><strong>Description:</strong> @(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-3">
            <a asp-action="Index" class="btn btn-outline-light rounded-3 flex-grow-1 py-2">
                <i class="fa-solid fa-xmark me-2"></i>Cancel
            </a>
            <button type="submit" class="btn btn-danger rounded-3 flex-grow-1 py-2 btn-glow-danger">
                <i class="fa-solid fa-trash-can me-2"></i>Confirm Delete
            </button>
        </div>
    </form>
</div>
