@model IEnumerable<ExpenseTracker.Models.Category>
@{
    ViewData["Title"] = "Categories";
    Layout = "_Layout";
    bool isAdmin = User.IsInRole("Admin");
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-0 text-white"><i class="fa-solid fa-tags text-primary me-2"></i>Categories</h1>
            <p class="text-muted small mb-0">Manage and view income/expense categories</p>
        </div>
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-primary rounded-3 btn-glow-primary text-white">
                <i class="fa-solid fa-plus me-2"></i>Add Category
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success-glass alert-dismissible fade show border-0 text-success rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger-glass alert-dismissible fade show border-0 text-danger rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!isAdmin)
    {
        <div class="alert alert-info-glass border-0 text-info rounded-3 mb-4 p-3 d-flex align-items-center">
            <i class="fa-solid fa-circle-info fa-lg me-3"></i>
            <div>
                <span class="fw-bold">Notice:</span> System-wide categories are read-only. Please contact your administrator if you need new categories added.
            </div>
        </div>
    }

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            var isIncome = item.Type == "Income";
            <div class="col">
                <div class="card glass-panel h-100 border-light border-opacity-10 rounded-3 hover-lift">
                    <div class="card-body p-4 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="category-icon-wrapper rounded-3 d-flex align-items-center justify-content-center me-3" 
                                 style="background-color: @(item.Color + "20"); width: 50px; height: 50px;">
                                <i class="fa-solid @item.Icon fa-xl" style="color: @item.Color"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold text-white mb-1">@item.Name</h5>
                                <span class="badge @(isIncome ? "bg-success-glass text-success" : "bg-danger-glass text-danger") rounded-pill px-2.5 py-1 small">
                                    <i class="fa-solid @(isIncome ? "fa-circle-arrow-down" : "fa-circle-arrow-up") me-1"></i>@item.Type
                                </span>
                            </div>
                        </div>

                        @if (isAdmin)
                        {
                            <div class="dropdown">
                                <button class="btn btn-link text-light opacity-50 p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa-solid fa-ellipsis-vertical fa-lg"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark bg-dark-glass border-light border-opacity-10 rounded-3">
                                    <li>
                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id">
                                            <i class="fa-solid fa-pen-to-square me-2 text-warning"></i>Edit
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.Id">
                                            <i class="fa-solid fa-trash-can me-2"></i>Delete
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
