@model ExpenseTracker.Models.Category
@{
    ViewData["Title"] = "Delete Category";
    Layout = "_Layout";
    bool canDelete = ViewBag.CannotDeleteMessage == null;
}

<div class="container py-4" style="max-width: 600px;">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-light btn-sm rounded-3">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to List
        </a>
        <h1 class="h3 fw-bold text-white mt-3"><i class="fa-solid fa-triangle-exclamation text-danger me-2"></i>Delete Category</h1>
        <p class="text-muted small">Are you sure you want to delete this category?</p>
    </div>

    @if (!canDelete)
    {
        <div class="alert alert-danger-glass border-0 text-danger rounded-3 p-3 mb-4 d-flex align-items-start">
            <i class="fa-solid fa-circle-xmark fa-xl me-3 mt-1"></i>
            <div>
                <h5 class="fw-bold mb-1">Cannot Delete Category</h5>
                <p class="small mb-0">@ViewBag.CannotDeleteMessage</p>
            </div>
        </div>
    }

    <div class="card glass-panel border-light border-opacity-10 rounded-3 p-4 shadow mb-4">
        <div class="d-flex align-items-center mb-3">
            <div class="category-icon-wrapper rounded-3 d-flex align-items-center justify-content-center me-3" 
                 style="background-color: @(Model.Color + "20"); width: 60px; height: 60px;">
                <i class="fa-solid @Model.Icon fa-2x" style="color: @Model.Color"></i>
            </div>
            <div>
                <h4 class="fw-bold text-white mb-1">@Model.Name</h4>
                <span class="badge @(Model.Type == "Income" ? "bg-success-glass text-success" : "bg-danger-glass text-danger") rounded-pill px-3 py-1">
                    @Model.Type
                </span>
            </div>
        </div>

        <hr class="border-light border-opacity-10" />

        <div class="text-light opacity-75 small">
            <p><strong>Database ID:</strong> @Model.Id</p>
            <p><strong>Color Code:</strong> <span style="color: @Model.Color">@Model.Color</span></p>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-3">
            <a asp-action="Index" class="btn btn-outline-light rounded-3 flex-grow-1 py-2">
                <i class="fa-solid fa-xmark me-2"></i>Cancel
            </a>
            @if (canDelete)
            {
                <button type="submit" class="btn btn-danger rounded-3 flex-grow-1 py-2 btn-glow-danger">
                    <i class="fa-solid fa-trash-can me-2"></i>Confirm Delete
                </button>
            }
            else
            {
                <button type="button" class="btn btn-secondary rounded-3 flex-grow-1 py-2" disabled>
                    <i class="fa-solid fa-ban me-2"></i>Delete Locked
                </button>
            }
        </div>
    </form>
</div>
