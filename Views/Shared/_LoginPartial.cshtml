@using Microsoft.AspNetCore.Identity
@using ExpenseTracker.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var name = user?.FullName ?? User.Identity?.Name ?? "User";

    <div class="d-flex align-items-center gap-3 px-3 py-3 mt-auto border-top border-light border-opacity-10 bg-dark bg-opacity-20">
        <div class="user-avatar rounded-circle bg-primary bg-opacity-25 d-flex align-items-center justify-content-center fw-bold text-primary" style="width: 40px; height: 40px;">
            @(!string.IsNullOrEmpty(name) ? name[0].ToString().ToUpper() : "U")
        </div>
        <div class="user-info flex-grow-1 overflow-hidden">
            <span class="d-block text-white small fw-bold text-truncate">@name</span>
            <span class="d-block text-muted small text-truncate">@User.Identity?.Name</span>
        </div>
        <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
            <button type="submit" class="btn btn-link text-danger p-0" title="Sign Out">
                <i class="fa-solid fa-right-from-bracket fa-lg"></i>
            </button>
        </form>
    </div>
}
else
{
    <div class="d-flex flex-column gap-2 p-3 mt-auto border-top border-light border-opacity-10">
        <a class="btn btn-outline-light btn-sm rounded-3" asp-controller="Account" asp-action="Login">
            <i class="fa-solid fa-right-to-bracket me-2"></i>Sign In
        </a>
        <a class="btn btn-primary btn-sm rounded-3" asp-controller="Account" asp-action="Register">
            <i class="fa-solid fa-user-plus me-2"></i>Sign Up
        </a>
    </div>
}
