@using Microsoft.AspNetCore.Identity
@using ExpenseTracker.Models
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Expense Tracker</title>
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- FontAwesome 6 Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Custom site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ExpenseTracker.styles.css" asp-append-version="true" />
</head>
<body>
    @if (SignInManager.IsSignedIn(User))
    {
        <div class="layout-wrapper">
            <!-- Sidebar -->
            <aside class="sidebar d-flex flex-column" id="appSidebar">
                <!-- Sidebar Brand logo -->
                <div class="brand px-4 py-4 d-flex align-items-center gap-2 border-bottom border-light border-opacity-10">
                    <i class="fa-solid fa-wallet text-primary fa-xl"></i>
                    <span class="fs-5 fw-bold text-white tracking-wide">ExpenseTracker</span>
                </div>

                <!-- Navigation links -->
                <nav class="flex-grow-1 py-3">
                    <a asp-controller="Dashboard" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="fa-solid fa-chart-pie"></i>Dashboard
                    </a>
                    <a asp-controller="Transaction" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transaction" ? "active" : "")">
                        <i class="fa-solid fa-receipt"></i>Transactions
                    </a>
                    <a asp-controller="Budget" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Budget" ? "active" : "")">
                        <i class="fa-solid fa-scale-balanced"></i>Budgets
                    </a>
                    <a asp-controller="Category" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                        <i class="fa-solid fa-tags"></i>Categories
                    </a>
                </nav>

                <!-- User Profile / Auth Status -->
                <partial name="_LoginPartial" />
            </aside>

            <!-- Main Contents Section -->
            <div class="main-content d-flex flex-column min-vh-100 flex-grow-1" style="padding-left: 0;">
                <!-- Header (Top Nav for Mobile Toggler) -->
                <header class="d-md-none glass-panel px-4 py-3 border-0 border-bottom border-light border-opacity-10 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa-solid fa-wallet text-primary fa-lg"></i>
                        <span class="fw-bold text-white small">ExpenseTracker</span>
                    </div>
                    <button class="btn btn-link text-white p-0" type="button" onclick="toggleSidebar()">
                        <i class="fa-solid fa-bars fa-lg"></i>
                    </button>
                </header>

                <main role="main" class="container-fluid px-4 py-3 flex-grow-1">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <!-- Simple layout for anonymous pages (Login/Register) -->
        <main role="main" class="min-vh-100">
            @RenderBody()
        </main>
    }

    <!-- jQuery and Bootstrap bundle JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('appSidebar');
            sidebar.classList.toggle('open');
        }
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
