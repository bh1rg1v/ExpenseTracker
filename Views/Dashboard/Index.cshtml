@model ExpenseTracker.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Financial Dashboard";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <!-- Welcome Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-0 text-white"><i class="fa-solid fa-chart-line text-primary me-2"></i>Dashboard</h1>
            <p class="text-muted small mb-0">Overview of your personal finances for @DateTime.Today.ToString("MMMM yyyy")</p>
        </div>
        <div>
            <a asp-controller="Transaction" asp-action="Create" class="btn btn-primary rounded-3 btn-glow-primary text-white">
                <i class="fa-solid fa-plus me-2"></i>Quick Add
            </a>
        </div>
    </div>

    <!-- Analytics Cards -->
    <div class="row g-4 mb-4">
        <!-- Income Card -->
        <div class="col-12 col-md-4">
            <div class="card glass-panel border-light border-opacity-10 rounded-3 p-4 hover-lift">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small text-uppercase tracking-wider d-block mb-1">Monthly Income</span>
                        <h2 class="fw-bold text-success mb-0">$@Model.TotalIncome.ToString("N2")</h2>
                    </div>
                    <div class="widget-icon rounded-3 bg-success bg-opacity-20 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="fa-solid fa-arrow-down-long text-success fa-xl animate-bounce"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Expense Card -->
        <div class="col-12 col-md-4">
            <div class="card glass-panel border-light border-opacity-10 rounded-3 p-4 hover-lift">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small text-uppercase tracking-wider d-block mb-1">Monthly Expenses</span>
                        <h2 class="fw-bold text-danger mb-0">$@Model.TotalExpense.ToString("N2")</h2>
                    </div>
                    <div class="widget-icon rounded-3 bg-danger bg-opacity-20 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="fa-solid fa-arrow-up-long text-danger fa-xl animate-bounce"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Net Savings Card -->
        <div class="col-12 col-md-4">
            <div class="card glass-panel border-light border-opacity-10 rounded-3 p-4 hover-lift">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small text-uppercase tracking-wider d-block mb-1">Net Savings</span>
                        <h2 class="fw-bold @(Model.NetBalance >= 0 ? "text-primary" : "text-warning") mb-0">$@Model.NetBalance.ToString("N2")</h2>
                    </div>
                    <div class="widget-icon rounded-3 bg-primary bg-opacity-20 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="fa-solid fa-scale-balanced text-primary fa-xl"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4 mb-4">
        <!-- Monthly Cash Flow -->
        <div class="col-12 col-lg-8">
            <div class="card glass-panel border-light border-opacity-10 rounded-3 p-4 shadow">
                <h5 class="fw-bold text-white mb-3"><i class="fa-solid fa-chart-column text-primary me-2"></i>Cash Flow Trend (Last 6 Months)</h5>
                <div style="height: 300px; position: relative;">
                    <canvas id="cashFlowChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Category Breakdown -->
        <div class="col-12 col-lg-4">
            <div class="card glass-panel border-light border-opacity-10 rounded-3 p-4 shadow">
                <h5 class="fw-bold text-white mb-3"><i class="fa-solid fa-chart-pie text-primary me-2"></i>Expense Breakdown</h5>
                <div style="height: 300px; position: relative;">
                    @if (Model.CategoryData.Any())
                    {
                        <canvas id="categoryChart"></canvas>
                    }
                    else
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                            <i class="fa-solid fa-chart-pie fa-3x mb-2 opacity-50"></i>
                            <span class="small">No expenses recorded this month.</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Lists Row -->
    <div class="row g-4">
        <!-- Recent Transactions -->
        <div class="col-12 col-lg-7">
            <div class="card glass-panel border-light border-opacity-10 rounded-3 p-4 shadow h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold text-white mb-0"><i class="fa-solid fa-history text-primary me-2"></i>Recent Transactions</h5>
                    <a asp-controller="Transaction" asp-action="Index" class="btn btn-outline-light btn-sm rounded-pill px-3">View All</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-light small">
                        <tbody>
                            @if (!Model.RecentTransactions.Any())
                            {
                                <tr>
                                    <td class="text-center py-4 text-muted">
                                        No recent transactions.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var t in Model.RecentTransactions)
                                {
                                    var isIncome = t.Category?.Type == "Income";
                                    <tr>
                                        <td class="py-2.5">
                                            <div class="d-flex align-items-center">
                                                <div class="category-icon-wrapper rounded-3 d-flex align-items-center justify-content-center me-2.5" 
                                                     style="background-color: @(t.Category?.Color + "20"); width: 28px; height: 28px;">
                                                    <i class="fa-solid @(t.Category?.Icon ?? "fa-tags") small" style="color: @t.Category?.Color"></i>
                                                </div>
                                                <span class="fw-semibold">@t.Category?.Name</span>
                                            </div>
                                        </td>
                                        <td class="py-2.5 text-muted text-truncate" style="max-width: 150px;">
                                            @(string.IsNullOrEmpty(t.Description) ? "—" : t.Description)
                                        </td>
                                        <td class="py-2.5 text-end font-monospace fw-bold @(isIncome ? "text-success" : "text-danger")">
                                            @(isIncome ? "+" : "-") $@t.Amount.ToString("N2")
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Budget Status -->
        <div class="col-12 col-lg-5">
            <div class="card glass-panel border-light border-opacity-10 rounded-3 p-4 shadow h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold text-white mb-0"><i class="fa-solid fa-bullseye text-primary me-2"></i>Monthly Budget Status</h5>
                    <a asp-controller="Budget" asp-action="Index" class="btn btn-outline-light btn-sm rounded-pill px-3">Manage</a>
                </div>

                <div class="d-flex flex-column gap-3">
                    @if (!Model.Budgets.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            No active budgets set for this month.
                        </div>
                    }
                    else
                    {
                        @foreach (var budget in Model.Budgets)
                        {
                            var pct = budget.ProgressPercentage;
                            var isOver = budget.IsOverBudget;
                            var isNear = budget.IsNearLimit;
                            string colorClass = isOver ? "bg-danger" : isNear ? "bg-warning" : "bg-success";
                            
                            <div>
                                <div class="d-flex justify-content-between text-light small mb-1">
                                    <span class="fw-semibold"><i class="fa-solid @budget.CategoryIcon me-1" style="color: @budget.CategoryColor"></i>@budget.CategoryName</span>
                                    <span>$@budget.SpentAmount.ToString("N0") / $@budget.LimitAmount.ToString("N0")</span>
                                </div>
                                <div class="progress bg-dark bg-opacity-40 rounded-pill" style="height: 6px;">
                                    <div class="progress-bar @colorClass rounded-pill" role="progressbar" style="width: @pct%" aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Cash Flow Chart Data
        const monthlyLabels = @Html.Raw(Json.Serialize(Model.MonthlyLabels));
        const monthlyIncomeData = @Html.Raw(Json.Serialize(Model.MonthlyIncomeData));
        const monthlyExpenseData = @Html.Raw(Json.Serialize(Model.MonthlyExpenseData));

        // Category Doughnut Chart Data
        const categoryLabels = @Html.Raw(Json.Serialize(Model.CategoryLabels));
        const categoryData = @Html.Raw(Json.Serialize(Model.CategoryData));
        const categoryColors = @Html.Raw(Json.Serialize(Model.CategoryColors));

        // 1. Render Cash Flow Chart
        const flowCtx = document.getElementById('cashFlowChart').getContext('2d');
        new Chart(flowCtx, {
            type: 'bar',
            data: {
                labels: monthlyLabels,
                datasets: [
                    {
                        label: 'Income',
                        data: monthlyIncomeData,
                        backgroundColor: '#2ec4b6',
                        borderRadius: 5,
                        maxBarThickness: 30
                    },
                    {
                        label: 'Expenses',
                        data: monthlyExpenseData,
                        backgroundColor: '#e63946',
                        borderRadius: 5,
                        maxBarThickness: 30
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        labels: { color: '#dee2e6', font: { family: 'Outfit' } }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#adb5bd', font: { family: 'Outfit' } }
                    },
                    y: {
                        grid: { color: 'rgba(255, 255, 255, 0.05)' },
                        ticks: { color: '#adb5bd', font: { family: 'Outfit' } }
                    }
                }
            }
        });

        // 2. Render Category Doughnut Chart
        if (categoryData && categoryData.length > 0) {
            const pieCtx = document.getElementById('categoryChart').getContext('2d');
            new Chart(pieCtx, {
                type: 'doughnut',
                data: {
                    labels: categoryLabels,
                    datasets: [{
                        data: categoryData,
                        backgroundColor: categoryColors,
                        borderWidth: 0,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#dee2e6', font: { family: 'Outfit', size: 11 }, boxWidth: 12 }
                        }
                    },
                    cutout: '65%'
                }
            });
        }
    </script>
}
